IDR_MENU MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "About...\tF1",                MENU_ABOUT
        MENUITEM "Change Device /  Mode...\tF2", IDM_CHANGEDEVICE
        MENUITEM SEPARATOR
        MENUITEM "E&xit\tESC",                  IDM_EXIT
    END
    POPUP "&Render"
    BEGIN
        MENUITEM "Flat Shading",                MENU_FLAT_SHADING
        MENUITEM "Gouraud Shading",             MENU_GOURAUD_SHADING
    END
    POPUP "&Lighting"
    BEGIN
        MENUITEM "Light Sources",               MENU_LIGHT_SOURCES
    END
END

