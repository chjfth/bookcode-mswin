    CONTROL         "&Stereoscopic viewing",IDC_STEREO_CHECKBOX,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,10,70,85,9
    DEFPUSHBUTTON   "OK",IDOK,125,5,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,125,25,50,14
END

