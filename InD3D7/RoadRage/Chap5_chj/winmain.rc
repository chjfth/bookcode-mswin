    CONTROL         "Render &back wall as grid",IDC_CKB_BackWallGrid,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,4,87,93,10
    CONTROL         "Render botto&m as grid",IDC_CKB_BottomGrid,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,99,87,87,10
    CONTROL         "Render &right wall as grid",IDC_CKB_RightWallGrid,
